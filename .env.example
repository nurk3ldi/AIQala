PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
CORS_CREDENTIALS=false
TRUST_PROXY=1

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=smart_city
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_LOGGING=false
DB_AUTO_SYNC=true
DB_AUTO_ALTER=true

JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_ISSUER=smart-city-issue-tracker
JWT_AUDIENCE=smart-city-clients

UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_MB=25

SEED_ADMIN_ON_STARTUP=false
DEFAULT_ADMIN_NAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

AI_ENABLED=false
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash
GEMINI_MODEL_DRAFT=gemini-2.5-flash
GEMINI_MODEL_MODERATION=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=30000
AI_FAIL_CLOSED=true

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX_REQUESTS=30
AUTH_LOCK_MAX_ATTEMPTS=5
AUTH_LOCK_WINDOW_MS=900000
AUTH_LOCK_DURATION_MS=1800000
