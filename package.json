{
  "name": "smart-city-issue-tracker-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for a smart city issue tracking system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:app": "node scripts/dev-all.cjs",
    "fast:app": "npm run build:app && npm start",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "build:app": "npm run build && npm run frontend:build",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "db:migrate": "sequelize-cli db:migrate --config sequelize-cli.config.cjs",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config sequelize-cli.config.cjs"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "postgresql",
    "sequelize",
    "express",
    "smart-city"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^20.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.1",
    "rimraf": "^6.0.1",
    "sequelize-cli": "^6.6.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
